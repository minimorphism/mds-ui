{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ESNext",
		"lib": ["DOM", "DOM.Iterable", "ESNext"],
		"declaration": true,
		"declarationDir": "dist/types",
		"emitDeclarationOnly": false,
		"outDir": "dist",
		"jsx": "react-jsx",
		"moduleResolution": "bundler",
		"esModuleInterop": true,
		"skipLibCheck": true,
		"strict": true,
		"isolatedModules": true
	},
	"include": ["src/**/*.ts"]
}
