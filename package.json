{
	"name": "@minimorphism/mds-ui",
	"version": "1.0.1",
	"repository": {
		"type": "git",
		"url": "git+https://github.com"
	},
	"type": "module",
	"private": false,
	"main": "dist/index.js",
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": [
		"dist"
	],
	"sideEffects": [
		"**/*.css",
		"**/*.scss",
		"src/**/*Shader.ts"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./dist/index.css": "./dist/index.css"
	},
	"scripts": {
		"build": "tsup",
		"build:clean": "rimraf dist && tsup",
		"story": "storybook dev -p 6006",
		"build:story": "storybook build",
		"typecheck": "tsc --noEmit",
		"test": "vitest",
		"test:ui": "vitest --ui"
	},
	"peerDependencies": {
		"react": "^18.0.0 || ^19.0.0",
		"react-dom": "^18.0.0 || ^19.0.0"
	},
	"devDependencies": {
		"@storybook/addon-docs": "^10.4.4",
		"@storybook/addon-links": "^10.4.6",
		"@storybook/addon-themes": "^10.4.4",
		"@storybook/react-vite": "^10.4.4",
		"@testing-library/jest-dom": "^6.4.5",
		"@testing-library/react": "^15.0.6",
		"@testing-library/user-event": "^14.5.2",
		"@types/react": "^18.3.2",
		"@types/react-dom": "^18.3.0",
		"@types/testing-library__jest-dom": "^5.14.9",
		"@vitejs/plugin-react": "^4.2.1",
		"esbuild-plugin-glsl": "^1.4.1",
		"esbuild-sass-plugin": "^3.3.0",
		"jsdom": "^24.0.0",
		"npmignore": "^0.3.1",
		"prettier": "3.2.5",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"rimraf": "^5.0.5",
		"sass-embedded": "^1.100.0",
		"storybook": "^10.4.4",
		"terser": "^5.47.1",
		"tsup": "^8.0.2",
		"typescript": "^5.4.5",
		"vite": "^5.2.11",
		"vite-plugin-glsl": "^1.3.0",
		"vitest": "^1.6.0"
	}
}
